begin
	GReset = 1'b1;
	GReset = #360000 1'b0;
	GReset = #40000 1'b1;
	GReset = #320000 1'b0;
	GReset = #40000 1'b1;
	GReset = #360000 1'b0;
	GReset = #40000 1'b1;
