	.MantissaOut(MantissaOut),
	.SignA(SignA),
	.SignB(SignB),
	.SignOut(SignOut)
);

// GClock
always
begin
	GClock = 1'b0;
	GClock = #10000 1'b1;
	#10000;
end 

